generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CEO
  TELLER
  COLLECTOR
  MEMBER
}

enum KycStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum AccountStatus {
  ACTIVE
  FROZEN
  CLOSED
}

enum DepositKind {
  FD
  RD
}

enum LoanStatus {
  APPLIED
  APPROVED
  DISBURSED
  CLOSED
  DEFAULTED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  APPROVE
  REJECT
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role
  status       String   @default("ACTIVE")
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  createdBy    String?
  member       Member?
  auditLogs    AuditLog[]
}

model Member {
  id          String        @id @default(uuid())
  userId      String        @unique
  user        User          @relation(fields: [userId], references: [id])
  fullName    String
  dob         DateTime
  contact     String
  address     String
  kycStatus   KycStatus     @default(PENDING)
  joinedOn    DateTime      @default(now())
  branchId    String?
  accounts    Account[]
  deposits    Deposit[]
  loans       Loan[]
  shares      Share[]
  kycDocs     KycDocument[]
  dividendPayouts DividendPayout[]
}

model KycDocument {
  id         String    @id @default(uuid())
  memberId   String
  member     Member    @relation(fields: [memberId], references: [id])
  type       String
  docNumber  String
  fileUrl    String
  status     KycStatus @default(PENDING)
  verifiedBy String?
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
}

model Share {
  id           String   @id @default(uuid())
  memberId     String
  member       Member   @relation(fields: [memberId], references: [id])
  certificateNo String
  units        Int
  faceValue    Decimal  @db.Decimal(12,2)
  issuedAt     DateTime @default(now())
}

model Account {
  id        String        @id @default(uuid())
  memberId  String
  member    Member        @relation(fields: [memberId], references: [id])
  type      String
  number    String        @unique
  balance   Decimal       @db.Decimal(14,2) @default(0)
  status    AccountStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  deposits  Deposit[]
}

model Deposit {
  id            String       @id @default(uuid())
  memberId      String
  member        Member       @relation(fields: [memberId], references: [id])
  accountId     String
  account       Account      @relation(fields: [accountId], references: [id])
  kind          DepositKind
  principal     Decimal      @db.Decimal(14,2)
  rate          Decimal      @db.Decimal(7,4)
  tenureMonths  Int
  startDate     DateTime
  maturityDate  DateTime
  payoutMode    String
  status        String       @default("ACTIVE")
  schedules     DepositSchedule[]
}

model DepositSchedule {
  id         String    @id @default(uuid())
  depositId  String
  deposit    Deposit   @relation(fields: [depositId], references: [id])
  dueDate    DateTime
  amount     Decimal   @db.Decimal(14,2)
  paid       Boolean   @default(false)
  txnId      String?
}

model Loan {
  id              String      @id @default(uuid())
  memberId        String
  member          Member      @relation(fields: [memberId], references: [id])
  product         String
  principal       Decimal     @db.Decimal(14,2)
  rate            Decimal     @db.Decimal(7,4)
  tenureMonths    Int
  sanctionDate    DateTime
  disbursedOn     DateTime?
  status          LoanStatus  @default(APPLIED)
  collateral      String?
  emiAmount       Decimal?    @db.Decimal(14,2)
  nextDueDate     DateTime?
  schedules       EmiSchedule[]
}

model EmiSchedule {
  id                  String   @id @default(uuid())
  loanId              String
  loan                Loan     @relation(fields: [loanId], references: [id])
  dueDate             DateTime
  principalComponent  Decimal  @db.Decimal(14,2)
  interestComponent   Decimal  @db.Decimal(14,2)
  totalDue            Decimal  @db.Decimal(14,2)
  paid                Boolean  @default(false)
  paidOn              DateTime?
  penalty             Decimal? @db.Decimal(12,2)
}

model LedgerAccount {
  id        String  @id @default(uuid())
  code      String  @unique
  name      String
  type      String
  parentId  String?
  parent    LedgerAccount? @relation("SubAccounts", fields: [parentId], references: [id])
  children  LedgerAccount[] @relation("SubAccounts")
}

model Transaction {
  id           String   @id @default(uuid())
  refType      String
  refId        String
  drAccountId  String
  crAccountId  String
  amount       Decimal  @db.Decimal(14,2)
  narration    String
  txnDate      DateTime @default(now())
  createdBy    String?
}

model Dividend {
  id            String      @id @default(uuid())
  fiscalYear    String
  totalProfit   Decimal     @db.Decimal(14,2)
  declaredOn    DateTime
  payoutRate    Decimal     @db.Decimal(7,4)
  status        String      @default("DECLARED")
  payouts       DividendPayout[]
}

model DividendPayout {
  id          String   @id @default(uuid())
  dividendId  String
  dividend    Dividend @relation(fields: [dividendId], references: [id])
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id])
  amount      Decimal  @db.Decimal(14,2)
  paidOn      DateTime?
  txnId       String?
}

model AuditLog {
  id        String      @id @default(uuid())
  actorId   String?
  actor     User?       @relation(fields: [actorId], references: [id])
  action    AuditAction
  entity    String
  entityId  String
  ip        String?
  userAgent String?
  diff      Json?
  createdAt DateTime @default(now())
}
